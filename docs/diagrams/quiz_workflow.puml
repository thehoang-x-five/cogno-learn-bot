@startuml chatbot_quiz_workflow
!theme plain
title Chatbot - Quiz Workflow
skinparam backgroundColor #FFFFFF

|Student|
start
:Yêu cầu "tạo quiz" trong chat\nhoặc mở quiz đã có;

if (Quiz AI từ chat?) then (yes)
  |AgentOrchestrator|
  :Gọi quiz_generator;
  |QuizGenerator|
  :Lấy context từ document chunks;
  :Gemini sinh câu hỏi trắc nghiệm;
  :Lưu vào generated_quizzes;
  |Frontend|
  :Hiển thị quiz card / nút làm quiz;
else (quiz đã có)
  |Frontend|
  :Mở trang chi tiết quiz;
endif

|Student|
:Làm bài;
:Submit answers;

|Quiz Router|
:POST /api/quizzes/{quiz_id}/attempts;
:Chấm điểm;
:Lưu quiz_attempts;
:Trả score + đáp án + lời giải;

|Teacher|
:Có thể tạo quiz thủ công;

|Quiz Router|
:POST /api/quizzes;
:Lưu quiz thủ công vào generated_quizzes;

|Teacher / Admin|
:Xem attempts và thống kê;

|Quiz Router|
:GET /api/quizzes/{quiz_id}/attempts;
:GET /api/quizzes/stats/course/{course_id};
:Export attempts / stats nếu cần;

stop

note bottom
Theo source:
- Quiz thủ công và quiz AI đều lưu ở bảng generated_quizzes
- Bài làm của sinh viên lưu ở quiz_attempts
- Dữ liệu câu hỏi lưu dưới dạng JSON trong cột questions
end note

@enduml

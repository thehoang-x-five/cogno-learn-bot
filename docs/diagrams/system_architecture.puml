@startuml chatbot_system_architecture
!theme plain
title Chatbot - System Architecture
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle

actor "Student" as Student
actor "Teacher" as Teacher
actor "Admin" as Admin

rectangle "Frontend\nReact + Vite + TypeScript" as FE {
  component "Auth pages" as FEAuth
  component "Course / Document UI" as FECourse
  component "Chat UI (SSE)" as FEChat
  component "Quiz UI" as FEQuiz
  component "Admin UI" as FEAdmin
}

rectangle "Backend\nFastAPI" as BE {
  component "Routers\n(auth, chat, documents,\nadmin, courses, quizzes,\nme, notifications)" as Routers
  component "ChatService" as ChatService
  component "RAGService" as RAGService
  component "AgentOrchestrator" as Agent
  component "DocumentService" as DocumentService
  component "MemoryManager /\nRollingSummaryService" as Memory
  component "GuardrailsService" as Guardrails
  component "PromptService" as PromptService
  component "LLMService" as LLMService
}

rectangle "Async Worker\nCelery" as Worker {
  component "process_document task" as ProcessDoc
  component "create_notifications task" as NotifyTask
}

database "MySQL" as MySQL
database "ChromaDB" as Chroma
database "Redis" as Redis
collections "Uploads\nlocal volume" as Uploads

cloud "Google OAuth" as Google
cloud "Gemini API" as Gemini

Student --> FE
Teacher --> FE
Admin --> FE

FE --> Routers : HTTP / SSE
Routers --> ChatService
Routers --> DocumentService
Routers --> MySQL
Routers --> Redis

ChatService --> Guardrails
ChatService --> Memory
ChatService --> Agent
ChatService --> RAGService
ChatService --> LLMService
ChatService --> PromptService
ChatService --> MySQL
ChatService --> Redis

RAGService --> Chroma : vector search
RAGService --> MySQL : BM25 + chunk metadata

Agent --> LLMService : function calling
Agent --> MySQL : exam schedules / quizzes

DocumentService --> Uploads
DocumentService --> MySQL : create document record
DocumentService --> Redis : Celery broker
DocumentService --> ProcessDoc

ProcessDoc --> Uploads
ProcessDoc --> MySQL : documents + chunks
ProcessDoc --> Chroma : embeddings + metadata
ProcessDoc --> NotifyTask

LLMService --> Gemini
Routers --> Google : OAuth callback flow

note bottom
Thực tế hiện tại:
- Backend là FastAPI, không phải Django
- CSDL chính là MySQL
- Vector DB là ChromaDB
- Queue / cache là Redis + Celery
- LLM hiện dùng Gemini API
end note

@enduml

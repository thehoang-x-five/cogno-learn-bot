@startuml chatbot_sequence_chat
!theme plain
title Chatbot - Chat Sequence
autonumber

actor User
participant Frontend
participant "Chat Router" as Router
participant ChatService
participant Guardrails
participant Redis
participant MemoryManager as Memory
participant RAGService as RAG
participant AgentOrchestrator as Agent
participant "Gemini API" as Gemini
database MySQL
database ChromaDB as Chroma

User -> Frontend: Gửi câu hỏi
Frontend -> Router: POST /api/conversations/{id}/messages (SSE)
Router -> Router: Verify JWT + conversation + enrollment
Router -> ChatService: process_message(...)

ChatService -> Redis: dedup cache lookup
alt Dedup hit
  Redis --> ChatService: cached answer + metadata
  ChatService -> Frontend: token events
  ChatService -> MySQL: save assistant message
  ChatService -> Frontend: metadata + done
else Cache miss
  ChatService -> Guardrails: check_input(content)
  alt Blocked
    Guardrails --> ChatService: violation
    ChatService -> Frontend: error
  else Passed
    Guardrails --> ChatService: ok
    ChatService -> MySQL: save user message
    ChatService -> Redis: memory cache lookup
    alt Memory miss
      ChatService -> Memory: get_context(...)
      Memory -> MySQL: load history / summaries
      Memory --> ChatService: memory context
    else Memory hit
      Redis --> ChatService: cached history
    end

    ChatService -> Gemini: intent classification
    alt Intent = GREETING / CHITCHAT / CONVERSATIONAL
      Gemini --> ChatService: direct response
      ChatService -> Frontend: token events
      ChatService -> MySQL: save assistant message
    else Intent = SCHEDULE_QUERY / QUIZ_REQUEST
      ChatService -> Agent: process(...)
      Agent -> Gemini: function calling
      Agent -> MySQL: schedule or quiz data
      Agent --> ChatService: response + metadata
      ChatService -> Frontend: token events
      ChatService -> MySQL: save assistant message
    else Intent = KNOWLEDGE_QA
      ChatService -> RAG: retrieve(query, course_id)
      par Hybrid retrieve
        RAG -> Chroma: vector search
        Chroma --> RAG: candidates
      and
        RAG -> MySQL: BM25 over chunks
        MySQL --> RAG: candidates
      end
      RAG -> RAG: RRF + rerank + citations
      RAG --> ChatService: chunks + citations
      ChatService -> Gemini: stream completion
      loop token stream
        Gemini --> ChatService: token
        ChatService -> Frontend: token
      end
      ChatService -> Frontend: citations
      ChatService -> MySQL: save assistant message + citations
    end

    ChatService -> Redis: invalidate memory cache
    ChatService -> Redis: store dedup cache
    ChatService -> Frontend: metadata + done
  end
end

@enduml

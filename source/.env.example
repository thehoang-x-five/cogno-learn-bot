# ═══════════════════════════════════════════════════════
# ENVIRONMENT TEMPLATE - Copy to .env and fill in values
# ═══════════════════════════════════════════════════════

# ─── MySQL Database ───────────────────────────────────
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_USER=chatuser
MYSQL_PASSWORD=your_password_here
MYSQL_DB=chatbox
MYSQL_DATABASE=chatbox
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ─── JWT Configuration ────────────────────────────────
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google OAuth ─────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ─── Frontend URL ─────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Gemini LLM (Google AI — Free Tier) ───────────────
# Get free API keys from: https://aistudio.google.com/apikey
# Multiple keys (comma-separated) for rate limit handling
GEMINI_API_KEY=your_gemini_api_key_1,your_gemini_api_key_2,your_gemini_api_key_3
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ─── Embedding Model ──────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# ─── ChromaDB (Vector Database) ───────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=edu_chunks

# ─── Redis (Caching & Background Tasks) ───────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/2

# ─── Celery (Background Tasks) ────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Cache Settings ───────────────────────────────────
DEDUP_CACHE_TTL=5
MEMORY_CACHE_TTL=60

# ─── RAG Timeout Settings ─────────────────────────────
RAG_RETRIEVE_TIMEOUT=8.0
RAG_RERANK_TIMEOUT=3.0
INTENT_DETECT_TIMEOUT=5.0
MEMORY_RECALL_TIMEOUT=5.0

# ─── CORS Origins (comma-separated) ───────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

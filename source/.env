# ─── RAG Timeout Settings ─────────────────────────────
# FIX: Increased timeouts to handle:
# - Reranking model loading (3.5s) + inference (2.5s) = 6s
# - Fallback ladder retries (3 steps)
# - Parallel search + RRF fusion + reranking = 10-15s total
INTENT_DETECT_TIMEOUT=15.0
RAG_RETRIEVE_TIMEOUT=30.0
RAG_RERANK_TIMEOUT=10.0
MEMORY_RECALL_TIMEOUT=5.0

# ─── Cache Settings ───────────────────────────────────
DEDUP_CACHE_TTL=5
MEMORY_CACHE_TTL=60
REDIS_URL=redis://redis:6379/2

# ─── Embedding ────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# ─── ChromaDB (Vector Database) ───────────────────────
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=edu_chunks

